Options -Indexes

php_value upload_max_filesize 20M
php_value post_max_size 25M

<FilesMatch "^(\.env|\.ini|\.log|composer\.json|package\.json)$">
    Require all denied
</FilesMatch>

<FilesMatch "^\.">
    Require all denied
</FilesMatch>

RewriteEngine On

RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^(.*)$ $1.php [NC,L]
